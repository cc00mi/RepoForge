# ============================================================================
# Repoforge — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================================

# LLM API Key (DeepSeek, OpenAI, or Anthropic)
DEEPSEEK_API_KEY=sk-your-key-here

# GitHub App credentials (required for webhook server)
GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY_PATH: 指定 PEM 私钥文件路径（推荐，可避免 .env 多行值警告）
#   将 GitHub App 的私钥保存为一个 .pem 文件（如 github-app.pem），
#   然后在下面填写相对于项目根目录的路径：
GITHUB_APP_PRIVATE_KEY_PATH=./github-app.pem
GITHUB_WEBHOOK_SECRET=

# GitHub personal token (for CLI commands like review)
GITHUB_TOKEN=

# Server port
PORT=8000
DASHBOARD_PORT=8001
